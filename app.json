{
  "expo": {
    "name": "Verim",
    "slug": "verim",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "verim",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tevertechnology.verim",
      "infoPlist": {
        "NSCameraUsageDescription": "Sayacınızı kamerayla okuyabilmek için kamera izni gereklidir."
      }
    },
    "android": {
      "package": "com.tevertechnology.verim",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#070A13"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Sayacınızı kamerayla okuyabilmek için kamera izni gereklidir.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#00FF9D",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
